<!doctype html>
<html lang="ru">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Absolute Champion Live Baseline v2026-07</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
:root{--line:rgba(255,255,255,.1);--text:#f5f5f7;--muted:#9ca3af;--green:#30d158;--red:#ff453a}
*{box-sizing:border-box}
body{margin:0;color:var(--text);font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",sans-serif;background:radial-gradient(circle at 20% 0,rgba(10,132,255,.22),transparent 33%),radial-gradient(circle at 85% 0,rgba(48,209,88,.12),transparent 28%),linear-gradient(180deg,#06080c,#090c10)}
.app{display:grid;grid-template-columns:285px 1fr;min-height:100vh}
aside{position:sticky;top:0;height:100vh;padding:28px 20px;border-right:1px solid var(--line);background:rgba(12,16,22,.86)}
.logo{width:52px;height:52px;border-radius:15px;background:linear-gradient(145deg,#fff,#b8bec8);color:#05070a;display:grid;place-items:center;font-weight:900;font-size:26px}
.brand{display:flex;gap:14px;align-items:center;margin-bottom:36px}.brand h1{margin:0;font-size:23px;line-height:1.05}.brand p{margin:5px 0 0;color:var(--muted);font-size:13px}
nav a{display:block;color:#d1d5db;text-decoration:none;padding:13px 16px;border-radius:15px;margin:6px 0;font-size:15px}nav a:hover,nav a.active{background:rgba(255,255,255,.08);color:#fff}
.side-card{position:absolute;left:20px;right:20px;bottom:30px;border:1px solid var(--line);border-radius:20px;padding:18px;background:rgba(255,255,255,.045)}
main{padding:30px 36px 42px}
.top{display:flex;justify-content:space-between;gap:20px;margin-bottom:22px}.title h2{font-size:39px;line-height:1;margin:0 0 8px}.title p{margin:0;color:#9fb4c9;font-size:16px}.badge{font-size:13px;color:var(--green);border:1px solid rgba(48,209,88,.35);border-radius:999px;padding:5px 10px;margin-left:10px}.pill{border:1px solid var(--line);border-radius:999px;padding:12px 18px;background:rgba(255,255,255,.06);height:max-content}
.grid{display:grid;gap:16px}.kpis{grid-template-columns:repeat(6,1fr);margin-bottom:16px}.card{border:1px solid var(--line);border-radius:20px;background:linear-gradient(145deg,rgba(255,255,255,.075),rgba(255,255,255,.035));padding:18px;box-shadow:0 20px 60px rgba(0,0,0,.35);overflow:hidden}
.label{color:#c7c7cc;font-size:13px;margin-bottom:10px}.value{font-size:30px;font-weight:800;letter-spacing:-.03em}.sub{color:var(--muted);font-size:13px;margin-top:6px}.green{color:var(--green)}.red{color:var(--red)}
.charts{grid-template-columns:1.12fr .88fr;margin-bottom:16px}.chart-card{height:345px}.chart-card canvas{width:100%!important;height:265px!important}
.section-title{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}.section-title h3{margin:0;font-size:18px}.section-title span{color:var(--muted);font-size:13px}
.lower{grid-template-columns:1fr 1fr;margin-bottom:16px}.mini-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.mini{border:1px solid var(--line);border-radius:15px;padding:13px;background:rgba(0,0,0,.15)}.mini b{display:block;font-size:21px;margin:5px 0}
.month-grid{display:grid;gap:10px}.month-row{display:grid;grid-template-columns:68px repeat(12,1fr);gap:6px}.year-label{font-weight:800;color:#cbd5e1;padding-top:15px}.month-cell{border:1px solid var(--line);border-radius:11px;padding:8px;background:rgba(255,255,255,.045);min-height:50px}.month-name{font-size:11px;color:var(--muted)}.month-ret{font-weight:800;font-size:14px;margin-top:4px}
table{width:100%;border-collapse:collapse;font-size:13px}th,td{padding:10px;border-bottom:1px solid var(--line);text-align:right;white-space:nowrap}th:first-child,td:first-child{text-align:left}th{color:var(--muted);font-weight:600}.table-wrap{overflow:auto;max-height:560px}
#error{display:none;position:fixed;z-index:9999;left:16px;right:16px;top:16px;background:#ff453a;color:white;border-radius:14px;padding:14px;font-weight:700}
@media(max-width:1100px){.app{grid-template-columns:1fr}aside{display:none}main{padding:16px}.kpis,.charts,.lower{grid-template-columns:1fr}.mini-grid{grid-template-columns:1fr}.month-row{grid-template-columns:1fr 1fr 1fr}}
</style>
</head>
<body>
<div id="error"></div>
<div class="app">
<aside>
<div class="brand"><div class="logo">A</div><div><h1>Live Baseline<br>v2026-07</h1><p>3m + 1h dashboard</p></div></div>
<nav><a class="active" href="#overview">⌘ Overview</a><a href="#charts">↗ Performance</a><a href="#monthly">▦ Monthly</a><a href="#instruments">◎ Instruments</a><a href="#exits">● Exits</a></nav>
<div class="side-card"><div class="label">Baseline</div><h3 class="green">SOL70 / NEAR30</h3><p>Entry TF <b style="float:right">3m</b></p><p>Trend TF <b style="float:right">1h</b></p><p>LINK <b style="float:right">OFF</b></p></div>
</aside>
<main id="overview">
<div class="top"><div class="title"><h2>Absolute Champion <span class="badge">Live Baseline v2026-07</span></h2><p>SOL70 / NEAR30 · 3m / 1h · Monthly Fixed-Return Compounding</p></div><div class="pill">STATIC ANALYTICS</div></div>
<div class="grid kpis" id="kpis"></div>
<div class="grid charts" id="charts">
<div class="card chart-card"><div class="section-title"><h3>Equity Curve</h3><span id="eqLabel"></span></div><canvas id="eqChart"></canvas></div>
<div class="card chart-card"><div class="section-title"><h3>Drawdown Curve</h3><span id="ddLabel"></span></div><canvas id="ddChart"></canvas></div>
</div>
<div class="grid lower">
<div class="card"><div class="section-title"><h3>Monthly Summary</h3><span>best / worst / average</span></div><div class="mini-grid" id="monthlySummary"></div></div>
<div class="card" id="exits"><div class="section-title"><h3>Exit Statistics</h3><span>TP / SL / Reverse</span></div><div class="mini-grid" id="exitStats"></div></div>
</div>
<div class="card" id="monthly" style="margin-bottom:16px"><div class="section-title"><h3>Monthly Performance</h3><span>all months</span></div><div class="month-grid" id="monthGrid"></div></div>
<div class="card" id="instruments" style="margin-bottom:16px"><div class="section-title"><h3>Instrument Summary</h3><span>SOL / NEAR / LINK</span></div><div class="mini-grid" id="instSummary"></div></div>
<div class="card" style="margin-bottom:16px"><div class="section-title"><h3>Monthly Instrument PnL</h3><span>SOL / NEAR / LINK</span></div><div class="table-wrap"><table><thead><tr><th>Month</th><th>SOL PnL</th><th>NEAR PnL</th><th>LINK PnL</th><th>SOL %</th><th>NEAR %</th><th>LINK %</th></tr></thead><tbody id="instTable"></tbody></table></div></div>
</main>
</div>
<script>
const BASE='/champion-live-dashboard/data/baseline_v2026_07/';
const fmt=(v,d=2)=>Number(v||0).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});
const plus=v=>Number(v)>=0?'+':''; const cls=v=>Number(v)>=0?'green':'red'; const byId=id=>document.getElementById(id);
async function load(file){const url=BASE+file+'?v='+Date.now(); const r=await fetch(url,{cache:'no-store'}); if(!r.ok) throw new Error(url+' '+r.status); return await r.json();}
function kpi(l,v,s,c=''){return `<div class="card"><div class="label">${l}</div><div class="value ${c}">${v}</div><div class="sub">${s||''}</div></div>`}
function mini(l,v,s,c=''){return `<div class="mini"><span class="label">${l}</span><b class="${c}">${v}</b><span class="sub">${s||''}</span></div>`}
function chart(id,labels,data,color,fill){new Chart(byId(id),{type:'line',data:{labels,datasets:[{data,borderColor:color,backgroundColor:fill,borderWidth:2,tension:.22,pointRadius:0,fill:true}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false},ticks:{color:'#8b8f98',maxTicksLimit:8}},y:{grid:{color:'rgba(255,255,255,.08)'},ticks:{color:'#8b8f98'}}}}})}
(async()=>{try{
const [s,m,e,d,im,isum]=await Promise.all([load('summary.json'),load('monthly.json'),load('equity.json'),load('drawdown.json'),load('instrument_monthly.json'),load('instrument_summary.json')]);
byId('kpis').innerHTML=[
kpi('Total Return',`${plus(s.total_return_pct_summary)}${fmt(s.total_return_pct_summary)}%`,'summary.csv',cls(s.total_return_pct_summary)),
kpi('Final Equity',`$${fmt(s.final_equity)}`,'monthly fixed-return'),
kpi('Profit Factor',fmt(s.profit_factor,4),'summary.csv','green'),
kpi('Win Rate',`${fmt(s.win_rate,2)}%`,'summary.csv'),
kpi('Max Drawdown',`${fmt(s.max_drawdown_pct)}%`,'summary.csv','red'),
kpi('Total Trades',fmt(s.total_trades,0),`${s.total_months} months`)
].join('');
byId('eqLabel').textContent=`Start $${fmt(s.start_equity,0)} · End $${fmt(s.final_equity)}`;
byId('ddLabel').textContent=`Max DD ${fmt(s.max_drawdown_pct)}%`;
chart('eqChart',e.map(x=>x.month),e.map(x=>x.equity),'#30d158','rgba(48,209,88,.22)');
chart('ddChart',d.map(x=>x.month),d.map(x=>-Math.abs(x.drawdown_pct)),'#ff453a','rgba(255,69,58,.18)');
byId('monthlySummary').innerHTML=[
mini('Avg Month',`${plus(s.avg_monthly_return)}${fmt(s.avg_monthly_return)}%`,'mean Return %','green'),
mini('Best Month',`$${fmt(s.best_month.pnl)}`,`${s.best_month.month} · ${plus(s.best_month.return_pct)}${fmt(s.best_month.return_pct)}%`,'green'),
mini('Worst Month',`$${fmt(s.worst_month.pnl)}`,`${s.worst_month.month} · ${plus(s.worst_month.return_pct)}${fmt(s.worst_month.return_pct)}%`,'red'),
mini('Positive Months',`${s.positive_months}/${s.total_months}`,`${fmt(s.positive_months/s.total_months*100,1)}%`,'green'),
mini('Negative Months',`${s.negative_months}/${s.total_months}`,`${fmt(s.negative_months/s.total_months*100,1)}%`,'red'),
mini('Avg Trades / Month',fmt(s.avg_trades_per_month,1),'activity')
].join('');
byId('exitStats').innerHTML=[
mini('TP1 Count',fmt(s.tp1_count,0),'exit_type TP1 or hit_tp1','green'),
mini('TP2 Hits',fmt(s.tp2_count,0),'hit_tp2','green'),
mini('SL Count',fmt(s.sl_count,0),'exit_type SL','red'),
mini('Reverse Count',fmt(s.reverse_count,0),'exit contains REVERSE'),
mini('TP1 / SL Ratio',s.sl_count?fmt(s.tp1_count/s.sl_count,2):'—','rough quality'),
mini('Portfolio',`SOL ${s.portfolio.SOL}% / NEAR ${s.portfolio.NEAR}%`,'LINK off')
].join('');
const names=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']; let by={}; m.forEach(r=>{let y=r.month.slice(0,4), mi=Number(r.month.slice(5,7))-1; (by[y]??={})[mi]=r;});
byId('monthGrid').innerHTML=Object.keys(by).sort().map(y=>{let html=`<div class="year-label">${y}</div>`; for(let i=0;i<12;i++){let r=by[y][i]; html+=r?`<div class="month-cell"><div class="month-name">${names[i]}</div><div class="month-ret ${cls(r.return_pct)}">${plus(r.return_pct)}${fmt(r.return_pct,1)}%</div></div>`:`<div class="month-cell"><div class="month-name">${names[i]}</div><div class="month-ret">—</div></div>`} return `<div class="month-row">${html}</div>`}).join('');
byId('instSummary').innerHTML=isum.map(x=>mini(x.symbol,`$${fmt(x.pnl)}`,`${plus(x.return_pct_of_1000)}${fmt(x.return_pct_of_1000)}% · ${fmt(x.trades,0)} trades · WR ${fmt(x.win_rate,1)}%`,cls(x.pnl))).join('');
byId('instTable').innerHTML=im.map(r=>{let S=r.symbols||{};let sol=S.SOL||{},near=S.NEAR||{},link=S.LINK||{};return `<tr><td>${r.month}</td><td class="${cls(sol.pnl)}">$${fmt(sol.pnl)}</td><td class="${cls(near.pnl)}">$${fmt(near.pnl)}</td><td class="${cls(link.pnl)}">$${fmt(link.pnl)}</td><td class="${cls(sol.return_pct_of_1000)}">${plus(sol.return_pct_of_1000)}${fmt(sol.return_pct_of_1000)}%</td><td class="${cls(near.return_pct_of_1000)}">${plus(near.return_pct_of_1000)}${fmt(near.return_pct_of_1000)}%</td><td class="${cls(link.return_pct_of_1000)}">${plus(link.return_pct_of_1000)}${fmt(link.return_pct_of_1000)}%</td></tr>`}).join('');
}catch(e){byId('error').style.display='block';byId('error').textContent='Dashboard error: '+e.message;console.error(e)}})();
</script>
</body>
</html>
