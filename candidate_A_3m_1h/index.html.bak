
<!doctype html>
<html lang="ru">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Candidate-A 3m+1h Dashboard</title>
<style>
body{margin:0;background:#0b1020;color:#e9eefc;font-family:Arial,sans-serif}
.wrap{max-width:1500px;margin:0 auto;padding:28px}
h1{margin:0 0 8px;font-size:34px}
.sub{color:#9fb0d0;margin-bottom:24px}
.grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:24px}
.card{background:#121a33;border:1px solid #263556;border-radius:16px;padding:16px}
.label{color:#9fb0d0;font-size:13px}
.val{font-size:26px;font-weight:700;margin-top:8px}
.good{color:#7ee787} .bad{color:#ff7b72} .warn{color:#ffd166}
.section{margin-top:28px}
table{width:100%;border-collapse:collapse;background:#121a33;border-radius:16px;overflow:hidden}
th,td{padding:10px 12px;border-bottom:1px solid #263556;text-align:right}
th:first-child,td:first-child{text-align:left}
th{color:#9fb0d0;font-weight:600;background:#17213d}
.pos{color:#7ee787} .neg{color:#ff7b72}
.monthgrid td{font-size:14px}
.params{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.small{font-size:13px;color:#9fb0d0}
</style>
</head>
<body>
<div class="wrap">
<h1>Candidate-A Dashboard</h1>
<div class="sub">3m + 1h · SOL 70% / NEAR 30% / LINK 0% · BASE/REV TRAIL 0.75 · one_bar_confirm</div>

