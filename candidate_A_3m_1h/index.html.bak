<div class="card"><div class="label">Monthly PF</div><div class="val">2.13</div></div>
<div class="card"><div class="label">Средний месяц (No Reinvest)</div><div class="val good">6.35%</div></div>
<div class="card"><div class="label">Прибыльных месяцев</div><div class="val">64/66</div></div>

<div class="card"><div class="label">Лучший месяц</div><div class="val good">2021-01<br>159.52%</div></div>
<div class="card"><div class="label">Худший месяц</div><div class="val bad">2023-04<br>-0.19%</div></div>
